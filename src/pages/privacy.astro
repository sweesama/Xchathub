---
/**
 * privacy.astro — 隐私政策
 * AdSense 审批前置条件 + GDPR 合规
 */
import Layout from '../layouts/Layout.astro';

/* 动态生成 "最后更新" 日期，避免站点看起来没人维护 */
const today = new Date();
const lastUpdatedISO = today.toISOString().split('T')[0]; // YYYY-MM-DD
const lastUpdatedDisplay = today.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout
  title="Privacy Policy | XChat Hub"
  description="Privacy policy for XChat Hub, the unofficial XChat community resource site."
  canonicalPath="/privacy"
>
  <section class="section">
    <div class="container content-page">
      <h1>Privacy Policy</h1>
      <p class="text-muted" style="margin-bottom: 2rem;">Last updated: <time datetime={lastUpdatedISO}>{lastUpdatedDisplay}</time></p>

      <h2>Who We Are</h2>
      <p>XChat Hub is an <strong>unofficial</strong> community-driven information site about XChat. We are not affiliated with X Corp, Elon Musk, or any related entity. Our website address is: <code>https://xchat.wiki</code>.</p>

      <h2>What Data We Collect</h2>
      <h3>Telegram Channel &amp; Community Group</h3>
      <p>We operate a public Telegram channel (<a href="https://t.me/xchathubdirectory" target="_blank" rel="noopener noreferrer">@xchathubdirectory</a>) for XChat updates and a community group (<a href="https://t.me/Xchathubcommunity" target="_blank" rel="noopener noreferrer">@Xchathubcommunity</a>) for discussion. Both are handled entirely by Telegram — we do not collect or store your Telegram account information.</p>

      <h3>Group Submissions</h3>
      <p>If you submit a group to our directory, we collect the group name, invite link, category, and optional description you provide. This information will be displayed publicly on the Groups Directory page.</p>

      <h3>Analytics &amp; Cookies</h3>
      <p>We may use privacy-respecting analytics to understand site traffic (such as page views and referral sources). We do not use invasive tracking cookies. If we implement third-party advertising (e.g., Google AdSense), those providers may use cookies as described in their own privacy policies.</p>

      <h3>Third-Party Advertising</h3>
      <p>We may display advertisements served by third-party ad networks, including Google AdSense. These services may use cookies and similar technologies to serve ads based on your prior visits to this or other websites. You can opt out of personalized advertising by visiting <a href="https://www.google.com/settings/ads" target="_blank" rel="noopener noreferrer">Google Ads Settings</a>.</p>

      <h2>How We Use Your Data</h2>
      <ul>
        <li>Telegram channel: we do not collect or store subscriber data.</li>
        <li>Group submissions: displayed publicly on our Groups Directory.</li>
        <li>Analytics data: aggregated and anonymized to improve the website.</li>
      </ul>

      <h2>Your Rights</h2>
      <p>You may request deletion of your data at any time by contacting us. We will remove your group from the directory upon request. For the Telegram channel, you can leave at any time directly from the Telegram app.</p>

      <h2>Data Retention</h2>
      <p>Group directory submissions are retained as long as the directory is operational. We do not store any data from Telegram channel subscribers.</p>

      <h2>Changes to This Policy</h2>
      <p>We may update this privacy policy from time to time. Changes will be posted on this page with an updated revision date.</p>

      <h2>Contact</h2>
      <p>For any privacy-related questions, removal requests, or general inquiries, please reach out via our <a href="https://t.me/Xchathubcommunity" target="_blank" rel="noopener noreferrer">Telegram community group</a> — admins respond within 48 hours. You can also find more information on our <a href="/about">About page</a>.</p>
    </div>
  </section>
</Layout>

<style>
  .content-page {
    max-width: 720px;
  }

  .content-page h1 {
    margin-bottom: 0.5rem;
  }

  .content-page h2 {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-size: 1.375rem;
  }

  .content-page h3 {
    margin-top: 1.25rem;
    margin-bottom: 0.5rem;
    font-size: 1.0625rem;
  }

  .content-page p {
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }

  .content-page ul {
    color: var(--text-secondary);
    line-height: 1.7;
    padding-left: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .content-page li {
    margin-bottom: 0.375rem;
  }

  .content-page code {
    background: var(--bg-card);
    padding: 0.125rem 0.375rem;
    border-radius: 4px;
    font-size: 0.875rem;
  }
</style>
