---
/**
 * 404.astro — 自定义 404 页面
 * 把迷路的用户导流回首页和群组目录
 */
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page Not Found | XChat Hub"
  description="The page you're looking for doesn't exist. Head back to XChat Hub for Android status tracking and group discovery."
>
  <section class="section not-found">
    <div class="container">
      <p class="error-code">404</p>
      <h1>Page Not Found</h1>
      <p class="text-secondary" style="margin: 1rem auto 1.5rem; max-width: 420px;">
        The page you're looking for doesn't exist or has been moved. Try searching the group directory or jump to one of these pages:
      </p>

      <!-- 快速搜索跳转 -->
      <form action="/groups" method="get" class="search-404" role="search">
        <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.35-4.35"/>
        </svg>
        <input type="search" name="q" placeholder="Search groups — Crypto, AI, Gaming..." aria-label="Search groups directory" />
      </form>

      <div class="action-links">
        <a href="/" class="btn btn-primary">
          Android Tracker
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/groups" class="btn btn-secondary">Groups Directory</a>
        <a href="/about" class="btn btn-secondary">About</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .not-found {
    text-align: center;
    padding-top: 8rem;
    padding-bottom: 8rem;
  }

  .error-code {
    font-size: 6rem;
    font-weight: 800;
    font-family: var(--font-mono);
    color: var(--border-hover);
    line-height: 1;
    margin-bottom: 1rem;
    letter-spacing: -0.05em;
  }

  .action-links {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .search-404 {
    position: relative;
    max-width: 440px;
    margin: 0 auto 2rem;
  }

  .search-404 .search-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
    pointer-events: none;
  }

  .search-404 input {
    width: 100%;
    padding: 0.75rem 1rem 0.75rem 2.75rem;
    border-radius: var(--radius-full);
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    color: var(--text-primary);
    font-size: 0.9375rem;
    height: 2.75rem;
    outline: none;
    transition: border-color 0.15s;
  }

  .search-404 input:focus {
    border-color: var(--accent);
  }
</style>
