---
/**
 * communities-shutdown.astro — X Communities 关停专题页
 *
 * 关键事实（源：TechCrunch / Nikita Bier on X / 2026-04-23）：
 * - X 官布 Communities 功能将于 2026-05-30 关停
 * - 原因：使用率 < 0.4%，占 80% 的 spam 举报
 * - 迁移目标：XChat 群聊（当前 350 人，将扩到 500/1000）
 *
 * SEO 战略：捕获 "x communities shutting down", "x communities alternative",
 * "migrate from x communities", "when do x communities close" 等流量。
 */
import Layout from '../layouts/Layout.astro';
import {
  XCHAT_APP_STORE_URL,
  XCHAT_GROUP_LIMIT,
  XCHAT_LAUNCH_DISPLAY,
  XCHAT_TELEGRAM_CHANNEL_URL,
} from '../data/xchat';

/* Communities 官方关停时间 */
const SHUTDOWN_ISO = '2026-05-30T00:00:00Z';
const SHUTDOWN_DISPLAY = 'May 30, 2026';
const now = new Date();
const shutdownDate = new Date(SHUTDOWN_ISO);
const msLeft = shutdownDate.getTime() - now.getTime();
const daysLeft = Math.max(0, Math.ceil(msLeft / (1000 * 60 * 60 * 24)));
const isShutDown = msLeft <= 0;

/* JSON-LD: Article schema */
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: `X Communities Shuts Down ${SHUTDOWN_DISPLAY} — Migrate to XChat`,
  description: `X Communities will close on ${SHUTDOWN_DISPLAY}. XChat groups are the official replacement: encrypted, invite links, no algorithms, and owned by the same company.`,
  author: { '@type': 'Organization', name: 'XChat Hub' },
  publisher: { '@type': 'Organization', name: 'XChat Hub', url: 'https://xchat.directory' },
  datePublished: '2026-04-24',
  dateModified: new Date().toISOString().split('T')[0],
};

const migrationSteps = [
  {
    step: 1,
    title: 'Download XChat',
    desc: `Get the app free from the <a href="${XCHAT_APP_STORE_URL}" target="_blank" rel="noopener noreferrer">App Store</a> (iOS 16+). Sign in with your existing X account — no new signup needed.`,
  },
  {
    step: 2,
    title: 'Create Your Group',
    desc: `Tap "New Group", give it a name (same as your old Community if you want), and set it to "Public" or "Private". Up to ${XCHAT_GROUP_LIMIT} members at launch, growing to 1,000.`,
  },
  {
    step: 3,
    title: 'Share the Invite Link',
    desc: 'Generate a joinable link or QR code. Post it to your old X Community before it closes, tweet it, or email your members.',
  },
  {
    step: 4,
    title: 'Approve Members',
    desc: 'Unlike the open-for-all X Communities, XChat groups let you approve each join request. Keep your community quality high.',
  },
];

const features = [
  { icon: '🔒', title: 'End-to-End Encrypted', desc: 'Unlike X Communities, every message in XChat is encrypted. No data mining, no algorithmic manipulation.' },
  { icon: '🔗', title: 'Invite Links', desc: 'Share joinable links anywhere — tweets, Discord, email. Members click and request to join.' },
  { icon: '📱', title: 'Mobile-First', desc: 'Built for iPhone from day one. Fast, native, push notifications that actually work.' },
  { icon: '👥', title: 'Up to 1,000 Members', desc: `Starting at ${XCHAT_GROUP_LIMIT} and growing. Big enough for most communities, small enough to stay focused.` },
  { icon: '🚫', title: 'No Algorithm', desc: 'Chronological feed. No "suggested posts", no engagement bait, no shadowbanning.' },
  { icon: '🎙️', title: 'Voice & Video', desc: 'Group voice channels and video calls built-in. Host AMAs, town halls, or casual hangouts.' },
];
---

<Layout
  title={`X Communities Shutting Down ${SHUTDOWN_DISPLAY} — Migrate to XChat | XChat Hub`}
  description={`X officially announced Communities will close on ${SHUTDOWN_DISPLAY}. XChat group chats are the replacement — encrypted, invite links, owned by X Corp. Migrate your community before the deadline.`}
  jsonLd={articleJsonLd}
  canonicalPath="/communities-shutdown"
  breadcrumbs={[
    { name: 'Home', url: 'https://xchat.directory/' },
    { name: 'X Communities Alternative', url: 'https://xchat.directory/communities-shutdown/' },
  ]}
>
  <!-- ==================== HERO ==================== -->
  <section class="section hero">
    <div class="container">
      <span class="eyebrow">{isShutDown ? 'Communities Closed' : `${daysLeft} Days Until Shutdown`}</span>
      <h1>
        X Communities Closes<br />
        <span class="text-gradient">{SHUTDOWN_DISPLAY}.</span>
      </h1>
      <p class="lead text-secondary prose-body">
        On April 23, 2026, X head of product Nikita Bier announced Communities will be retired on
        <strong> <time datetime="2026-05-30">{SHUTDOWN_DISPLAY}</time></strong>.
        Reason: under 0.4% of users were active, but Communities generated 80% of spam reports.
        <strong>XChat is the official replacement</strong> — encrypted group chats, invite links,
        no algorithms. Migrate your members before the deadline.
      </p>

      {!isShutDown && (
        <div class="countdown-strip" aria-label="Days until X Communities shutdown">
          <div class="count-box">
            <span class="count-num">{daysLeft}</span>
            <span class="count-label">Day{daysLeft === 1 ? '' : 's'} left to migrate</span>
          </div>
        </div>
      )}

      <div class="cta-buttons">
        <a href={XCHAT_APP_STORE_URL} target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-lg">
          Download XChat Free
        </a>
        <a href="/how-to-create-group-link" class="btn btn-secondary btn-lg">
          How to Create Group Link
        </a>
      </div>
    </div>
  </section>

  <!-- ==================== WHY MIGRATE ==================== -->
  <section class="section">
    <div class="container">
      <div class="two-col">
        <div class="col-text">
          <h2>Why XChat Replaces X Communities</h2>
          <p class="text-secondary prose-body">
            X Communities (launched 2022) never quite worked. Algorithmic feeds buried posts. 
            Moderation tools were minimal. Discovery was broken.
          </p>
          <p class="text-secondary prose-body">
            XChat fixes all of this. It's a <strong>dedicated messaging app</strong>, not a social feed. 
            Messages arrive in order. Every member sees every message. And it's encrypted — 
            so your community discussions stay private.
          </p>
          <ul class="checklist">
            <li>No algorithm, chronological feed only</li>
            <li>End-to-end encrypted by default</li>
            <li>Invite links with admin approval</li>
            <li>Voice channels and video calls</li>
            <li>Screenshot blocking for sensitive chats</li>
            <li>Same login as your X account</li>
          </ul>
        </div>
        <div class="col-visual">
          <div class="comparison-card">
            <h3>X Communities</h3>
            <ul class="bad-list">
              <li>❌ Algorithmic feed</li>
              <li>❌ Not encrypted</li>
              <li>❌ No voice/video</li>
              <li>❌ Limited moderation</li>
              <li>❌ <strong>Shutting down</strong></li>
            </ul>
          </div>
          <div class="comparison-card good">
            <h3>XChat Groups</h3>
            <ul class="good-list">
              <li>✅ Chronological</li>
              <li>✅ E2E encrypted</li>
              <li>✅ Voice + video</li>
              <li>✅ Invite + approval</li>
              <li>✅ <strong>Live now (since {XCHAT_LAUNCH_DISPLAY})</strong></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== FEATURE GRID ==================== -->
  <section class="section features-section">
    <div class="container">
      <h2 class="section-title">What You Get with XChat</h2>
      <div class="feature-grid">
        {features.map((f) => (
          <article class="feature-card">
            <span class="feature-icon" aria-hidden="true">{f.icon}</span>
            <h3>{f.title}</h3>
            <p class="text-secondary">{f.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== MIGRATION STEPS ==================== -->
  <section class="section steps-section">
    <div class="container">
      <h2 class="section-title">Migrate in 4 Steps</h2>
      <div class="steps">
        {migrationSteps.map((s) => (
          <div class="step">
            <div class="step-number">{s.step}</div>
            <div class="step-content">
              <h3>{s.title}</h3>
              <p class="text-secondary" set:html={s.desc} />
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== FINAL CTA ==================== -->
  <section class="section final-section">
    <div class="container">
      <div class="final-card">
        <h2>Don't Let Your Community Die</h2>
        <p class="text-secondary prose-body">
          Thousands of X Communities are looking for a new home. XChat is the only option 
          built by X Corp, with the same account system your members already have. 
          Download now and start migrating before your old Community disappears.
        </p>
        <div class="cta-buttons" style="justify-content: center; margin-top: 1.5rem;">
          <a href={XCHAT_APP_STORE_URL} target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-lg">
            Download on App Store
          </a>
          <a href={XCHAT_TELEGRAM_CHANNEL_URL} target="_blank" rel="noopener noreferrer" class="btn btn-secondary btn-lg">
            Get Migration Tips on Telegram
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ---- Hero ---- */
  .hero {
    text-align: center;
    padding-top: 4rem;
    padding-bottom: 2rem;
  }

  .eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-light);
    margin-bottom: 1rem;
    padding: 0.3125rem 0.875rem;
    border: 1px solid rgba(29, 155, 240, 0.25);
    border-radius: var(--radius-full);
    background: rgba(29, 155, 240, 0.05);
  }

  .hero h1 {
    max-width: 700px;
    margin: 0 auto 1.25rem;
  }

  .lead {
    font-size: 1.125rem;
    max-width: 640px;
    margin: 0 auto 1.5rem;
  }

  .cta-buttons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.875rem;
  }

  /* ---- Countdown Strip ---- */
  .countdown-strip {
    display: flex;
    justify-content: center;
    margin: 0 auto 1.5rem;
  }

  .count-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1rem 2rem;
    border: 1px solid rgba(255, 99, 71, 0.35);
    border-radius: var(--radius-lg);
    background: linear-gradient(135deg, rgba(255, 99, 71, 0.08), rgba(29, 155, 240, 0.04));
  }

  .count-num {
    font-size: 2.5rem;
    font-weight: 800;
    line-height: 1;
    color: #ff6347;
    font-variant-numeric: tabular-nums;
  }

  .count-label {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: 0.375rem;
  }

  /* ---- Two Column ---- */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .col-text h2 {
    margin-bottom: 1rem;
  }

  .checklist {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
  }

  .checklist li {
    padding: 0.5rem 0;
    padding-left: 1.5rem;
    position: relative;
    color: var(--text-secondary);
  }

  .checklist li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 700;
  }

  /* ---- Comparison Cards ---- */
  .col-visual {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .comparison-card {
    padding: 1.5rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    background: var(--bg-card);
  }

  .comparison-card.good {
    border-color: rgba(29, 155, 240, 0.3);
    background: linear-gradient(135deg, rgba(29, 155, 240, 0.08), transparent);
  }

  .comparison-card h3 {
    font-size: 1rem;
    margin-bottom: 1rem;
    color: var(--text-secondary);
  }

  .comparison-card.good h3 {
    color: var(--accent-light);
  }

  .bad-list, .good-list {
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 0.9375rem;
  }

  .bad-list li, .good-list li {
    padding: 0.375rem 0;
  }

  /* ---- Features ---- */
  .features-section {
    background: linear-gradient(180deg, transparent, rgba(29, 155, 240, 0.03), transparent);
  }

  .section-title {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .feature-card {
    padding: 1.5rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    background: var(--bg-card);
    transition: border-color 0.2s, transform 0.2s;
  }

  .feature-card:hover {
    border-color: var(--border-hover);
    transform: translateY(-2px);
  }

  .feature-icon {
    display: block;
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .feature-card h3 {
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }

  .feature-card p {
    font-size: 0.875rem;
    line-height: 1.55;
  }

  /* ---- Steps ---- */
  .steps-section {
    background: var(--bg-card);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .steps {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .step {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .step-number {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--accent);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1rem;
    flex-shrink: 0;
  }

  .step-content h3 {
    font-size: 1.125rem;
    margin-bottom: 0.375rem;
    margin-top: 0.25rem;
  }

  .step-content p {
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  /* ---- Final CTA ---- */
  .final-section {
    padding-top: 2rem;
  }

  .final-card {
    max-width: 640px;
    margin: 0 auto;
    padding: 2.5rem;
    text-align: center;
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    background:
      radial-gradient(ellipse at top, rgba(29, 155, 240, 0.08), transparent 60%),
      var(--bg-card);
  }

  .final-card h2 {
    margin-bottom: 0.75rem;
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .two-col {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .col-visual {
      order: -1;
    }
    .feature-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
