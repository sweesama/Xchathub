---
/**
 * list-your-group.astro — 付费置顶 / 提交群组说明页
 * 商业链条的关键一页：说明定价 + Buy Me a Coffee 付款 + Telegram 人工对接流程
 *
 * ⚠️ 部署前你要做的事：
 *   1. 注册 Buy Me a Coffee 账号（https://www.buymeacoffee.com/）
 *   2. 把下面的 BMC_USERNAME 常量改成你的真实 username
 *   3. 在 BMC 后台创建两个 "Extras"：
 *       - $9  Featured Listing (30 days)
 *       - $29 Lifetime Listing + Category Pin
 *      记下 extras 的直链，可选替换下方的 /e/ 链接
 */
import Layout from '../layouts/Layout.astro';

// BMC 用户名（对应 https://buymeacoffee.com/Mzusama）
const BMC_USERNAME = 'Mzusama';
const BMC_URL = `https://www.buymeacoffee.com/${BMC_USERNAME}`;

// BMC Shop 商品直链（已配置，点击直接跳到商品结账页，省一步点击）
const BMC_SHOP_FEATURED = 'https://buymeacoffee.com/mzusama/e/530068'; // $9  Featured 30 天
const BMC_SHOP_LIFETIME = 'https://buymeacoffee.com/mzusama/e/530071'; // $29 Lifetime Pin

const plans = [
  {
    name: 'Free Submission',
    price: 0,
    priceLabel: 'Free',
    badge: null,
    features: [
      'Listed in category grid (alphabetical)',
      'Basic group card with name & description',
      'Included in site search',
      '24–72 hour review time',
    ],
    cta: { label: 'Submit via Telegram', href: 'https://t.me/Xchathubcommunity', variant: 'secondary' },
    description: 'Perfect for community groups, fan projects, and non-commercial communities.',
  },
  {
    name: 'Featured',
    price: 9,
    priceLabel: '$9',
    priceSuffix: '/ 30 days',
    badge: 'Most Popular',
    highlight: true,
    features: [
      'Pinned above free listings in category',
      '"Featured" badge on group card',
      'Priority review (within 24 hours)',
      'Renewable — pay again to extend',
    ],
    cta: { label: 'Get Featured — $9', href: BMC_SHOP_FEATURED || BMC_URL, variant: 'primary' },
    description: 'Best for small projects wanting extra visibility during launch rush.',
  },
  {
    name: 'Lifetime Pin',
    price: 29,
    priceLabel: '$29',
    priceSuffix: 'one-time',
    badge: 'Best Value',
    features: [
      'Permanently pinned at top of category',
      '"Lifetime" gold badge',
      'Priority review (within 12 hours)',
      'One-time payment, no renewals ever',
    ],
    cta: { label: 'Pin Lifetime — $29', href: BMC_SHOP_LIFETIME || BMC_URL, variant: 'primary' },
    description: 'Best for commercial projects, crypto/finance groups, long-term communities.',
  },
];

const pageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'XChat Group Directory Listing',
  provider: { '@type': 'Organization', name: 'XChat Hub' },
  areaServed: 'Worldwide',
  description: 'Submit your public XChat group to the XChat Hub directory. Free listings available; featured and lifetime pins available for a one-time fee.',
  offers: plans.map((p) => ({
    '@type': 'Offer',
    name: p.name,
    price: p.price,
    priceCurrency: 'USD',
    description: p.description,
  })),
};
---

<Layout
  title="List Your XChat Group — Free & Featured Listings | XChat Hub"
  description="Submit your XChat group to the largest unofficial directory. Free listings for community groups, $9 for 30-day featured pin, $29 for lifetime top placement."
  jsonLd={pageJsonLd}
  canonicalPath="/list-your-group"
  breadcrumbs={[
    { name: 'Home', url: 'https://xchat.directory/' },
    { name: 'Groups Directory', url: 'https://xchat.directory/groups/' },
    { name: 'List Your Group', url: 'https://xchat.directory/list-your-group/' },
  ]}
>
  <!-- ==================== HEADER ==================== -->
  <section class="section list-hero">
    <div class="container">
      <span class="eyebrow">For Group Owners</span>
      <h1>
        Put Your Group
        <span class="text-gradient">In Front of 10,000+ Viewers.</span>
      </h1>
      <p class="lead text-secondary prose-body">
        XChat Hub is the first and largest community directory for XChat groups. Submit your group free, or pay once to pin it at the top of its category for maximum visibility.
      </p>
    </div>
  </section>

  <!-- ==================== PRICING GRID ==================== -->
  <section class="section-sm">
    <div class="container">
      <div class="pricing-grid">
        {plans.map((plan) => (
          <article class={`pricing-card ${plan.highlight ? 'pricing-card-highlight' : ''}`}>
            {plan.badge && <span class="pricing-badge">{plan.badge}</span>}
            <header class="pricing-header">
              <h3 class="pricing-name">{plan.name}</h3>
              <div class="pricing-price">
                <span class="pricing-price-number">{plan.priceLabel}</span>
                {plan.priceSuffix && <span class="pricing-price-suffix">{plan.priceSuffix}</span>}
              </div>
              <p class="pricing-desc text-muted">{plan.description}</p>
            </header>
            <ul class="pricing-features">
              {plan.features.map((feature) => (
                <li>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M20 6 9 17l-5-5"/>
                  </svg>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
            <a
              href={plan.cta.href}
              target={plan.cta.href.startsWith('http') ? '_blank' : undefined}
              rel={plan.cta.href.startsWith('http') ? 'noopener noreferrer' : undefined}
              class={`btn btn-${plan.cta.variant} pricing-cta`}
            >
              {plan.cta.label}
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== HOW IT WORKS ==================== -->
  <section class="section">
    <div class="container">
      <div class="how-wrap">
        <h2>How It Works</h2>
        <p class="text-secondary prose-body" style="max-width: 560px; margin: 0.75rem auto 0;">
          Three steps, no account needed. Pay via Buy Me a Coffee (credit card or PayPal), then message us on Telegram with your receipt.
        </p>

        <ol class="how-steps">
          <li>
            <span class="how-num">1</span>
            <div>
              <h3>Choose a plan</h3>
              <p class="text-secondary">Free for community groups. Paid plans if you want guaranteed top placement.</p>
            </div>
          </li>
          <li>
            <span class="how-num">2</span>
            <div>
              <h3>Pay via Buy Me a Coffee <span class="how-sub">(paid plans only)</span></h3>
              <p class="text-secondary">Click the plan button above — Buy Me a Coffee accepts all major credit cards and PayPal. Save your receipt email.</p>
            </div>
          </li>
          <li>
            <span class="how-num">3</span>
            <div>
              <h3>Message us on Telegram</h3>
              <p class="text-secondary">Send your XChat group invite link + a short description to <a href="https://t.me/Xchathubcommunity" target="_blank" rel="noopener noreferrer">@Xchathubcommunity</a>. For paid plans, also attach your BMC receipt. Live within 24 hours.</p>
            </div>
          </li>
        </ol>
      </div>
    </div>
  </section>

  <!-- ==================== SUBMISSION FORM ==================== -->
  <section class="section" id="submit">
    <div class="container">
      <div class="form-wrap">
        <h2>Submit Your Group</h2>
        <p class="text-secondary prose-body" style="text-align: center; max-width: 560px; margin: 0.75rem auto 1.5rem;">
          Fill the form below and we'll review within 24 hours. Form submissions are delivered straight to our Telegram review queue.
        </p>

        <form id="submit-group-form" class="submit-form" autocomplete="off" novalidate>
          <!-- 蜜罐字段：人不会看到，bot 会填 -->
          <div class="hp-field" aria-hidden="true">
            <label>Website (do not fill)
              <input type="text" name="website" tabindex="-1" autocomplete="off" />
            </label>
          </div>

          <div class="form-grid">
            <label class="field">
              <span class="field-label">Plan</span>
              <select name="plan" required>
                <option value="Free">Free Submission</option>
                <option value="Featured ($9 / 30d)">Featured — $9 / 30 days</option>
                <option value="Lifetime ($29 one-time)">Lifetime Pin — $29 one-time</option>
              </select>
            </label>

            <label class="field">
              <span class="field-label">Category <span class="req">*</span></span>
              <select name="category" required>
                <option value="">— select —</option>
                <option>Crypto</option>
                <option>Tech</option>
                <option>AI</option>
                <option>News</option>
                <option>Sports</option>
                <option>Gaming</option>
                <option>Business</option>
                <option>Entertainment</option>
                <option>Education</option>
                <option>Local</option>
              </select>
            </label>

            <label class="field span-2">
              <span class="field-label">Group name <span class="req">*</span></span>
              <input type="text" name="groupName" required maxlength="120" placeholder="e.g. Solana Trading Floor" />
            </label>

            <label class="field span-2">
              <span class="field-label">XChat invite URL <span class="req">*</span></span>
              <input type="url" name="inviteUrl" required maxlength="300" pattern="https://x\.com/i/chat/group_join/.*" placeholder="https://x.com/i/chat/group_join/..." />
              <span class="field-hint">Must start with <code>https://x.com/i/chat/group_join/</code></span>
            </label>

            <label class="field span-2">
              <span class="field-label">Short description <span class="req">*</span></span>
              <textarea name="description" required maxlength="600" rows="3" placeholder="What is this group about? Who should join? Anything special about it?"></textarea>
              <span class="field-hint">Up to 600 characters.</span>
            </label>

            <label class="field">
              <span class="field-label">Member count</span>
              <input type="text" name="members" maxlength="20" inputmode="numeric" placeholder="e.g. 87" />
            </label>

            <label class="field">
              <span class="field-label">Tags (comma-separated)</span>
              <input type="text" name="tags" maxlength="200" placeholder="solana, defi, memecoins" />
            </label>

            <label class="field">
              <span class="field-label">Your X handle</span>
              <input type="text" name="ownerHandle" maxlength="60" placeholder="@yourhandle" />
            </label>

            <label class="field">
              <span class="field-label">Contact email (optional)</span>
              <input type="email" name="ownerEmail" maxlength="120" placeholder="you@example.com" />
            </label>

            <label class="field span-2">
              <span class="field-label">BMC receipt / order reference <span class="opt">(paid plans only)</span></span>
              <input type="text" name="bmcReceipt" maxlength="200" placeholder="Order ID or receipt email" />
            </label>
          </div>

          <button type="submit" class="btn btn-primary btn-lg form-submit">
            <span class="form-submit-label">Submit for Review →</span>
            <span class="form-submit-loading" hidden>Sending…</span>
          </button>
          <p class="form-fallback text-muted">
            Form not working? Send your details directly to
            <a href="https://t.me/Xchathubcommunity" target="_blank" rel="noopener noreferrer">@Xchathubcommunity</a>.
          </p>

          <!-- 状态消息容器 -->
          <div id="form-status" class="form-status" role="status" aria-live="polite" hidden></div>
        </form>
      </div>
    </div>
  </section>

  <!-- ==================== FAQ ==================== -->
  <section class="section">
    <div class="container">
      <div class="faq-wrap">
        <h2>Common Questions</h2>
        <div class="faq-list">
          <details open>
            <summary><h3 class="faq-q-title">Do I need an account to submit?</h3></summary>
            <div class="faq-body">No. We only need your XChat group invite link and a short description — sent via Telegram. No signup required.</div>
          </details>
          <details>
            <summary><h3 class="faq-q-title">What's the difference between Featured and Lifetime?</h3></summary>
            <div class="faq-body">Featured pins your group above free listings for 30 days (renewable). Lifetime pins it <strong>permanently</strong>, one-time payment, no recurring charge ever.</div>
          </details>
          <details>
            <summary><h3 class="faq-q-title">Can I get a refund?</h3></summary>
            <div class="faq-body">If your group violates our content guidelines (spam, illegal content, hate speech) we'll remove it without refund. Otherwise, we offer a 7-day no-questions-asked refund — just message us on Telegram.</div>
          </details>
          <details>
            <summary><h3 class="faq-q-title">Is crypto or direct bank transfer accepted?</h3></summary>
            <div class="faq-body">Not publicly yet. For orders over $100 or bulk listings, contact us on Telegram — we accept USDT (TRC20) by arrangement.</div>
          </details>
          <details>
            <summary><h3 class="faq-q-title">Why Buy Me a Coffee and not Stripe?</h3></summary>
            <div class="faq-body">We're a small team. Buy Me a Coffee lets us accept payments worldwide with minimal overhead (no incorporated business required). As we grow, we'll add Stripe Checkout for instant listing.</div>
          </details>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== FINAL CTA ==================== -->
  <section class="section final-section">
    <div class="container">
      <div class="final-card">
        <h2>Ready to Get Listed?</h2>
        <p class="text-secondary prose-body">
          Whether you want a free listing or a lifetime pin, the first step is the same — drop into our Telegram community and say hi. We typically respond within a few hours.
        </p>
        <a href="https://t.me/Xchathubcommunity" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-lg" style="margin-top: 1.5rem;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
          </svg>
          Message @Xchathubcommunity
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  /* ---- Submission form: POST /api/submit-group → Telegram ---- */
  const form = document.getElementById('submit-group-form') as HTMLFormElement | null;
  const statusEl = document.getElementById('form-status') as HTMLElement | null;
  if (form && statusEl) {
    const submitBtn = form.querySelector<HTMLButtonElement>('.form-submit');
    const labelEl = form.querySelector<HTMLElement>('.form-submit-label');
    const loadingEl = form.querySelector<HTMLElement>('.form-submit-loading');

    const setStatus = (kind: 'success' | 'error' | 'info', html: string) => {
      statusEl.hidden = false;
      statusEl.className = `form-status form-status-${kind}`;
      statusEl.innerHTML = html;
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.reportValidity()) return;

      const fd = new FormData(form);
      const payload: Record<string, string> = {};
      fd.forEach((v, k) => { payload[k] = String(v); });

      // UI: 进入加载态
      if (submitBtn) submitBtn.disabled = true;
      if (labelEl) labelEl.hidden = true;
      if (loadingEl) loadingEl.hidden = false;
      statusEl.hidden = true;

      try {
        const res = await fetch('/api/submit-group', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await res.json().catch(() => ({} as any));

        if (res.ok && data.ok) {
          setStatus(
            'success',
            '✓ Thanks! Your submission was sent to our review queue. We typically respond within 24 hours via your X handle or email.',
          );
          form.reset();
        } else {
          const msg = (data && data.error) || 'Submission failed. Please try again or message us on Telegram.';
          setStatus(
            'error',
            `✗ ${msg} <a href="https://t.me/Xchathubcommunity" target="_blank" rel="noopener noreferrer">Message @Xchathubcommunity →</a>`,
          );
        }
      } catch (err) {
        setStatus(
          'error',
          'Network error. Please check your connection or send your details to <a href="https://t.me/Xchathubcommunity" target="_blank" rel="noopener noreferrer">@Xchathubcommunity</a>.',
        );
      } finally {
        if (submitBtn) submitBtn.disabled = false;
        if (labelEl) labelEl.hidden = false;
        if (loadingEl) loadingEl.hidden = true;
      }
    });
  }
</script>

<style>
  /* ---- Hero ---- */
  .list-hero {
    text-align: center;
    padding-top: 6rem;
    padding-bottom: 2rem;
  }

  .eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-light);
    margin-bottom: 1.25rem;
    padding: 0.3125rem 0.875rem;
    border: 1px solid rgba(29, 155, 240, 0.25);
    border-radius: var(--radius-full);
    background: rgba(29, 155, 240, 0.05);
  }

  .list-hero h1 {
    max-width: 780px;
    margin: 0 auto 1.5rem;
  }

  .list-hero h1 .text-gradient {
    display: block;
    margin-top: 0.1em;
  }

  .lead {
    font-size: 1.125rem;
    max-width: 600px;
    margin: 0 auto;
  }

  /* ---- Pricing Grid ---- */
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.25rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .pricing-card {
    position: relative;
    padding: 2rem 1.75rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    background: var(--bg-card);
    display: flex;
    flex-direction: column;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.035) inset,
      0 1px 2px rgba(0, 0, 0, 0.4);
    transition: border-color 0.3s, transform 0.3s var(--ease-smooth);
  }

  .pricing-card:hover {
    border-color: var(--border-hover);
    transform: translateY(-2px);
  }

  /* 高亮方案：X 蓝外发光 + 更高的层次 */
  .pricing-card-highlight {
    border-color: rgba(29, 155, 240, 0.4);
    background:
      radial-gradient(ellipse at top, rgba(29, 155, 240, 0.06), transparent 70%),
      var(--bg-card);
    box-shadow:
      0 1px 0 rgba(29, 155, 240, 0.15) inset,
      0 0 0 1px rgba(29, 155, 240, 0.1),
      0 8px 32px rgba(29, 155, 240, 0.08);
  }

  .pricing-badge {
    position: absolute;
    top: -11px;
    left: 50%;
    transform: translateX(-50%);
    padding: 0.3125rem 0.875rem;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #fff;
    background: var(--accent);
    border-radius: var(--radius-full);
    box-shadow: 0 4px 16px var(--accent-glow);
  }

  .pricing-header {
    margin-bottom: 1.5rem;
  }

  .pricing-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-secondary);
    letter-spacing: 0.02em;
    margin-bottom: 0.5rem;
  }

  .pricing-price {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.875rem;
  }

  .pricing-price-number {
    font-size: 2.75rem;
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--text-primary);
  }

  .pricing-price-suffix {
    font-size: 0.875rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .pricing-desc {
    font-size: 0.8125rem;
    line-height: 1.55;
  }

  .pricing-features {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .pricing-features li {
    display: flex;
    gap: 0.625rem;
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .pricing-features svg {
    flex-shrink: 0;
    color: var(--accent-light);
    margin-top: 0.125rem;
  }

  .pricing-cta {
    width: 100%;
  }

  .submit-template {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    background: var(--bg-card);
    text-align: center;
  }

  .submit-template p {
    max-width: 560px;
    margin: 0.75rem auto 0;
  }

  .template-box {
    display: grid;
    gap: 0.5rem;
    margin: 1.5rem 0;
    padding: 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--bg-secondary);
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    line-height: 1.5;
    text-align: left;
  }

  /* ---- How It Works ---- */
  .how-wrap {
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
  }

  .how-steps {
    list-style: none;
    padding: 0;
    margin: 3rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-align: left;
  }

  .how-steps li {
    display: flex;
    gap: 1.25rem;
    padding: 1.25rem 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    transition: border-color 0.3s;
  }

  .how-steps li:hover {
    border-color: var(--border-hover);
  }

  .how-num {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--accent);
    color: #fff;
    font-weight: 700;
    font-size: 0.875rem;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.15) inset;
  }

  .how-steps h3 {
    font-size: 1rem;
    margin-bottom: 0.25rem;
  }

  .how-sub {
    color: var(--text-muted);
    font-weight: 400;
    font-size: 0.8125rem;
  }

  .how-steps p {
    font-size: 0.9375rem;
    line-height: 1.55;
  }

  /* ---- FAQ ---- */
  .faq-wrap {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }

