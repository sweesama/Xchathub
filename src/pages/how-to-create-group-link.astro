---
/**
 * how-to-create-group-link.astro — XChat 群组邀请链接完整教程
 *
 * 关键事实（源：roboin.io / Nikita Bier on X / 2026-04-23）：
 * - XChat 群组邀请链接已上线
 * - 流程：创建群 → 群信息 → "Group invite link" → 打开 toggle → 复制链接
 * - 链接接收者：发送加入请求 → 管理员审批
 * - 当前 350 人上限，将扩到 500 → 1,000
 *
 * SEO 战略：捕获超高流量低竞争长尾词：
 * "how to create xchat group link", "xchat group invite tutorial",
 * "share xchat group", "xchat groupchat link how to"
 */
import Layout from '../layouts/Layout.astro';
import {
  XCHAT_APP_STORE_URL,
  XCHAT_GROUP_LIMIT,
  XCHAT_TELEGRAM_CHANNEL_URL,
} from '../data/xchat';

/* JSON-LD: HowTo schema — 让 Google 把步骤显示为 Featured Snippet */
const howToJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to Create an XChat Group Invite Link',
  description: 'Step-by-step guide to create a group chat in XChat and generate a public invite link to share with anyone on X.',
  totalTime: 'PT3M',
  tool: [
    { '@type': 'HowToTool', name: 'XChat app (iOS)' },
    { '@type': 'HowToTool', name: 'X account' },
  ],
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: 'Open XChat and start a new group',
      text: 'Launch the XChat app on your iPhone or iPad. Tap the compose button (top-right pencil icon), then tap "Create a group" in the New Message dialog.',
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: 'Add at least one initial member',
      text: 'Search for and select at least one X user to add to the group. You cannot create an empty group. You can add more members later.',
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: 'Name your group',
      text: 'After the group is created, tap the group name at the top of the chat, then tap the edit (pencil) icon to set a custom name and description.',
    },
    {
      '@type': 'HowToStep',
      position: 4,
      name: 'Open Group invite link settings',
      text: 'In the group info panel, scroll down and tap "Group invite link". This is where you control who can join via a public link.',
    },
    {
      '@type': 'HowToStep',
      position: 5,
      name: 'Enable the Group link toggle',
      text: 'Turn ON the "Group link" toggle. XChat will generate a unique URL you can copy and share anywhere — tweets, Discord, email, or our directory.',
    },
    {
      '@type': 'HowToStep',
      position: 6,
      name: 'Approve incoming join requests',
      text: 'When someone clicks your link, they send a join request. Return to "Group invite link" in the group info panel — accept or reject each request.',
    },
  ],
};

const steps = [
  {
    n: 1,
    title: 'Open XChat & start a new group',
    body: 'Launch the XChat app on your iPhone or iPad. Tap the <strong>compose button</strong> (top-right pencil icon). When the New Message dialog appears, tap <strong>"Create a group"</strong>.',
    tip: 'Make sure you are on iOS 16 or later — XChat is iPhone/iPad only at launch.',
  },
  {
    n: 2,
    title: 'Add at least one member',
    body: 'Search for and select at least one X user to add. You can add as few as one to start — you can invite the rest later via your link.',
    tip: 'You cannot create an empty group. Pick any contact, even a test account, just to bootstrap.',
  },
  {
    n: 3,
    title: 'Name your group',
    body: 'After creation, tap the group name at the top of the chat. Tap the <strong>edit (pencil) icon</strong> to set a custom name and description.',
    tip: 'Use a clear, searchable name — the link page shows this name to anyone who clicks.',
  },
  {
    n: 4,
    title: 'Open Group invite link',
    body: 'In the group info panel, scroll until you see <strong>"Group invite link"</strong> and tap it. This screen controls public access.',
    tip: 'If you do not see the option, force-quit and reopen XChat — the feature may need a refresh.',
  },
  {
    n: 5,
    title: 'Enable the Group link toggle',
    body: 'Turn ON <strong>"Group link"</strong>. XChat generates a unique URL. Tap copy, then paste it anywhere — a tweet, your X bio, Discord, email, or submit to our <a href="/groups">XChat Groups Directory</a>.',
    tip: 'Anyone with the link can see the group name, member icons, and member count, but cannot read messages until approved.',
  },
  {
    n: 6,
    title: 'Approve join requests',
    body: 'When someone clicks your link, they send a request. Go back to <strong>"Group invite link"</strong> in the group info panel. Tap <strong>Accept</strong> to admit, or the ❌ to reject.',
    tip: 'You can revoke or regenerate the link at any time if it gets abused.',
  },
];

const faqs = [
  {
    q: 'How many members can join an XChat group?',
    a: `At launch, XChat groups support up to <strong>${XCHAT_GROUP_LIMIT} members</strong>. X has publicly stated that limit will expand to 500 and then 1,000 in upcoming updates.`,
  },
  {
    q: 'Does the invite link expire?',
    a: 'The link does not auto-expire, but you (the admin) can disable the toggle or regenerate the link at any time from the same screen.',
  },
  {
    q: 'Can I share the link outside of X?',
    a: 'Yes. The link is a normal URL — you can paste it on Discord, Telegram, WhatsApp, in an email, on a website, or in a tweet. Anyone with an X account can request to join.',
  },
  {
    q: 'Do I need to approve every member?',
    a: 'Yes. Joining via a link only sends a <strong>join request</strong> — admins must accept it before the user can read messages or post. This is the main difference from Telegram public links.',
  },
  {
    q: 'Can people on Android join my XChat group?',
    a: 'Not yet. XChat is iOS-only at launch. Android users can read group messages via <strong>chat.x.com</strong> on a desktop browser if they have an X account, but a native Android app has not been announced.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.a.replace(/<[^>]+>/g, ''),
    },
  })),
};

const combinedJsonLd = [howToJsonLd, faqJsonLd];
---

<Layout
  title="How to Create an XChat Group Invite Link — 6 Steps with Screenshots | XChat Hub"
  description="Step-by-step guide to create an XChat group chat and generate a public invite link to share on X, Discord, or anywhere. Includes member limits, approval flow, and FAQs."
  jsonLd={combinedJsonLd}
  canonicalPath="/how-to-create-group-link"
  ogImage="/og-guide.png"
  ogImageAlt="How to create an XChat group invite link — 6-step guide on xchat.directory"
  breadcrumbs={[
    { name: 'Home', url: 'https://xchat.directory/' },
    { name: 'How to Create Group Link', url: 'https://xchat.directory/how-to-create-group-link/' },
  ]}
>
  <!-- ==================== HERO ==================== -->
  <section class="section hero">
    <div class="container">
      <span class="eyebrow">XChat Tutorial · 3 min read</span>
      <h1>
        How to Create an XChat<br />
        <span class="text-gradient">Group Invite Link.</span>
      </h1>
      <p class="lead text-secondary prose-body">
        XChat launched April 24, 2026 with <strong>joinable group links</strong> —
        the official replacement for X Communities. Follow these 6 steps to spin up a public group and share the link in 3 minutes.
      </p>
      <div class="cta-buttons">
        <a href={XCHAT_APP_STORE_URL} target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-lg">
          Download XChat Free
        </a>
        <a href="#steps" class="btn btn-secondary btn-lg">
          Jump to Steps
        </a>
      </div>
    </div>
  </section>

  <!-- ==================== QUICK SUMMARY ==================== -->
  <section class="section quick-summary">
    <div class="container">
      <div class="summary-card">
        <h2>TL;DR — The 6 Taps</h2>
        <ol class="summary-list">
          <li>Compose <span class="kbd">+</span> → <strong>Create a group</strong></li>
          <li>Add <strong>at least one member</strong></li>
          <li>Tap group name → <strong>Edit</strong> name &amp; description</li>
          <li>Open <strong>Group invite link</strong></li>
          <li>Toggle <strong>Group link ON</strong> → copy URL</li>
          <li>Approve incoming <strong>join requests</strong></li>
        </ol>
      </div>
    </div>
  </section>

  <!-- ==================== DETAILED STEPS ==================== -->
  <section class="section steps-section" id="steps">
    <div class="container">
      <h2 class="section-title">Detailed Walkthrough</h2>
      <div class="steps">
        {steps.map((s) => (
          <article class="step-card">
            <div class="step-num" aria-hidden="true">{s.n}</div>
            <div class="step-body">
              <h3>{s.title}</h3>
              <p class="text-secondary" set:html={s.body} />
              <div class="step-tip">
                <strong>Tip:</strong> {s.tip}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== FAQ ==================== -->
  <section class="section faq-section">
    <div class="container">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-list">
        {faqs.map((f) => (
          <details class="faq-item">
            <summary>{f.q}</summary>
            <p class="text-secondary" set:html={f.a} />
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== RELATED ==================== -->
  <section class="section related-section">
    <div class="container">
      <h2 class="section-title">Next Steps</h2>
      <div class="related-grid">
        <a href="/groups" class="related-card">
          <h3>Browse XChat Groups Directory →</h3>
          <p class="text-secondary">Find active public groups by category or submit your own group link.</p>
        </a>
        <a href="/communities-shutdown" class="related-card">
          <h3>Migrating from X Communities →</h3>
          <p class="text-secondary">X Communities closes May 30, 2026. Move your community to XChat before the deadline.</p>
        </a>
        <a href="/list-your-group" class="related-card">
          <h3>List Your Group →</h3>
          <p class="text-secondary">Submit your group link to our directory and reach new members.</p>
        </a>
        <a href={XCHAT_TELEGRAM_CHANNEL_URL} target="_blank" rel="noopener noreferrer" class="related-card">
          <h3>Get Updates on Telegram →</h3>
          <p class="text-secondary">We post every new XChat feature, group, and Android update the moment it lands.</p>
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    text-align: center;
    padding-top: 4rem;
    padding-bottom: 2rem;
  }

  .eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-light);
    margin-bottom: 1rem;
    padding: 0.3125rem 0.875rem;
    border: 1px solid rgba(29, 155, 240, 0.25);
    border-radius: var(--radius-full);
    background: rgba(29, 155, 240, 0.05);
  }

  .hero h1 {
    max-width: 720px;
    margin: 0 auto 1.25rem;
  }

  .lead {
    font-size: 1.125rem;
    max-width: 640px;
    margin: 0 auto 1.5rem;
  }

  .cta-buttons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.875rem;
  }

  /* ---- Quick Summary ---- */
  .quick-summary {
    padding-top: 1rem;
    padding-bottom: 2rem;
  }

  .summary-card {
    max-width: 640px;
    margin: 0 auto;
    padding: 2rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    background: var(--bg-card);
  }

  .summary-card h2 {
    margin-bottom: 1rem;
    font-size: 1.25rem;
  }

  .summary-list {
    margin: 0;
    padding-left: 1.25rem;
    color: var(--text-secondary);
    line-height: 2;
  }

  .summary-list strong {
    color: var(--text-primary);
  }

  .kbd {
    display: inline-block;
    padding: 0.1rem 0.5rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    font-family: monospace;
    font-size: 0.85em;
    background: rgba(255, 255, 255, 0.04);
  }

  /* ---- Steps ---- */
  .steps-section {
    background: linear-gradient(180deg, transparent, rgba(29, 155, 240, 0.03), transparent);
  }

  .section-title {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .steps {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .step-card {
    display: flex;
    gap: 1.25rem;
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--bg-card);
  }

  .step-num {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--accent);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.125rem;
  }

  .step-body h3 {
    font-size: 1.0625rem;
    margin-bottom: 0.5rem;
    margin-top: 0.375rem;
  }

  .step-body p {
    font-size: 0.9375rem;
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .step-tip {
    font-size: 0.8125rem;
    color: var(--text-muted);
    padding: 0.625rem 0.875rem;
    border-left: 3px solid var(--accent);
    background: rgba(29, 155, 240, 0.05);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    line-height: 1.5;
  }

  .step-tip strong {
    color: var(--accent-light);
  }

  /* ---- FAQ ---- */
  .faq-section {
    border-top: 1px solid var(--border);
  }

  .faq-list {
    max-width: 720px;
    margin: 0 auto;
  }

  .faq-item {
    border-bottom: 1px solid var(--border);
    padding: 1rem 0;
  }

  .faq-item summary {
    cursor: pointer;
    font-weight: 600;
    font-size: 1rem;
    list-style: none;
    padding-right: 1.5rem;
    position: relative;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::after {
    content: '+';
    position: absolute;
    right: 0;
    top: 0;
    font-size: 1.5rem;
    line-height: 1;
    color: var(--accent);
    transition: transform 0.2s;
  }

  .faq-item[open] summary::after {
    content: '−';
  }

  .faq-item p {
    margin-top: 0.75rem;
    font-size: 0.9375rem;
    line-height: 1.65;
  }

  /* ---- Related ---- */
  .related-section {
    background: var(--bg-card);
    border-top: 1px solid var(--border);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
    max-width: 880px;
    margin: 0 auto;
  }

  .related-card {
    display: block;
    padding: 1.25rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--bg-primary);
    text-decoration: none;
    transition: border-color 0.2s, transform 0.2s;
  }

  .related-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .related-card h3 {
    font-size: 1rem;
    margin-bottom: 0.375rem;
    color: var(--text-primary);
  }

  .related-card p {
    font-size: 0.875rem;
    line-height: 1.5;
    margin: 0;
  }

  @media (max-width: 640px) {
    .step-card {
      flex-direction: column;
      gap: 0.75rem;
    }
  }
</style>
