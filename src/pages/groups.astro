---
import Layout from '../layouts/Layout.astro';
import { XCHAT_GROUP_LIMIT, XCHAT_LAUNCH_DATE, XCHAT_LAUNCH_DISPLAY } from '../data/xchat';
import {
  GROUP_CATEGORIES,
  GROUP_DISCOVERY_SIGNALS,
  SORTED_GROUP_DIRECTORY,
  getGroupListingBadge,
  getGroupListingTier,
} from '../data/groups';
import { GROUP_CATEGORY_META } from '../data/groupCategoryMeta';
import CategoryIcon from '../components/CategoryIcon.astro';

const groups = SORTED_GROUP_DIRECTORY;

const groupsJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'XChat Groups Directory',
  description: 'Discover and join public XChat groups and communities once invite links are available.',
  url: 'https://xchat.directory/groups',
};
---

<Layout
  title="XChat Groups Directory — Find & Share Group Links | XChat Hub"
  description={`The first community-powered directory for XChat group links. XChat launched ${XCHAT_LAUNCH_DISPLAY}. Submit your group and help others find your community.`}
  jsonLd={groupsJsonLd}
  canonicalPath="/groups"
  ogImage="/og-groups.png"
  ogImageAlt="Find and join public XChat groups — directory by xchat.directory"
  breadcrumbs={[
    { name: 'Home', url: 'https://xchat.directory/' },
    { name: 'Groups Directory', url: 'https://xchat.directory/groups/' },
  ]}
>
  <section class="section groups-hero" id="search">
    <div class="container">
      <h1 class="groups-title">
        Discover Top
        <span class="text-gradient">XChat Groups &amp; Communities</span>
      </h1>
      <p class="groups-subtitle text-secondary prose-body">
        XChat launched on <strong><time datetime={XCHAT_LAUNCH_DATE}>{XCHAT_LAUNCH_DISPLAY}</time></strong> with <strong>joinable group links</strong> — but no built-in group search. This directory fills that gap: discover and share public XChat groups before anyone else. <a href="https://t.me/xchathubdirectory" target="_blank" rel="noopener noreferrer">Get new groups via Telegram</a>.
      </p>

      <div class="search-box">
        <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.35-4.35"/>
        </svg>
        <input
          type="search"
          id="group-search"
          placeholder="Search groups by name, topic, or keyword..."
          aria-label="Search groups"
        />
      </div>

      <div class="tags-row" role="tablist" aria-label="Filter groups by category">
        {GROUP_CATEGORIES.map((cat, i) => (
          <button
            class={`tag ${i === 0 ? 'active' : ''}`}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            data-category={cat}
          >
            {cat}
          </button>
        ))}
      </div>
    </div>
  </section>

  <section class="section-sm" id="groups-grid">
    <div class="container">
      {groups.length > 0 ? (
        <div class="grid">
          {groups.map((group) => {
            const listingBadge = getGroupListingBadge(group);
            const listingTier = getGroupListingTier(group);
            const searchText = [
              group.name,
              group.description,
              group.category,
              ...group.tags,
            ].join(' ');

            return (
            <article
              class={`card group-card group-card-${listingTier}`}
              data-category={group.category}
              data-search={searchText}
            >
              <div class="group-card-header">
                <span class="group-icon">{group.icon}</span>
                <div>
                  <h3 class="group-name">{group.name}</h3>
                  <div class="group-meta">
                    <span class="tag btn-sm group-category">{group.category}</span>
                    {listingBadge && <span class={`group-badge group-badge-${listingTier}`}>{listingBadge}</span>}
                    {group.verifiedAt && <span class="group-verified">Verified</span>}
                  </div>
                </div>
              </div>
              <p class="group-desc text-secondary">{group.description}</p>
              <div class="group-tag-list">
                {group.tags.map((tag) => <span class="mini-tag">{tag}</span>)}
              </div>
              <div class="group-card-footer">
                <div class="members-info">
                  <div class="members-bar">
                    <div class="members-fill" style={`width: ${(group.members / XCHAT_GROUP_LIMIT) * 100}%`}></div>
                  </div>
                  <span class="members-count text-muted">{group.members} / {XCHAT_GROUP_LIMIT}</span>
                </div>
                <a href={group.inviteUrl} class="btn btn-primary btn-sm" target="_blank" rel="noopener noreferrer nofollow">
                  Join
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              </div>
              <a
                class="owner-removal"
                href={`mailto:hello@xchat.directory?subject=${encodeURIComponent(`Remove group: ${group.name}`)}&body=${encodeURIComponent(`I am the owner of "${group.name}" (slug: ${group.slug}) and I want it removed from xchat.directory.\n\nPlease confirm by replying within 24h.\n\n— Sent from xchat.directory`)}`}
              >
                Owner? Request removal
              </a>
            </article>
            );
          })}
        </div>
      ) : (
        <div class="coming-soon-state">
          <div class="coming-soon-icon" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="9" opacity="0.3"/>
              <circle cx="12" cy="12" r="5" opacity="0.6"/>
              <circle cx="12" cy="12" r="1.5" fill="currentColor"/>
            </svg>
          </div>
          <h3>Directory Opens When Real Invite Links Exist</h3>
          <p class="text-secondary prose-body">
            There are no verified public XChat groups listed yet. Once the app launches and invite links can be confirmed, this page will switch from placeholder state to a searchable live directory.
          </p>
          <p class="coming-soon-hint text-muted">
            Want to help seed it? <a href="/list-your-group">Submit your group</a> or share what you find after launch.
          </p>
        </div>
      )}

      <div class="empty-state" id="empty-state" style="display: none;">
        <p class="text-muted">No groups found. Try a different search or category.</p>
      </div>
    </div>
  </section>

  <section class="section-sm browse-categories">
    <div class="container">
      <div class="cat-header">
        <h2>Browse XChat Groups by Category</h2>
        <p class="text-secondary">Each category has its own page with groups, examples, and submission guidance.</p>
      </div>
      <div class="cat-grid">
        {GROUP_CATEGORY_META.map((cat) => (
          <a href={`/groups/${cat.slug}/`} class="cat-card">
            <span class="cat-icon" aria-hidden="true"><CategoryIcon slug={cat.slug} size={28} /></span>
            <h3>{cat.label}</h3>
            <p class="text-secondary">{cat.intro.split('.')[0]}.</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-sm">
    <div class="container">
      <div class="card discovery-card">
        <h2>How We’ll Find Real XChat Groups</h2>
        <p class="text-secondary prose-body">
          Until XChat is live, the directory is prepared but intentionally empty. We’ll only publish groups after we can verify how invites actually work.
        </p>
        <ul class="discovery-list">
          {GROUP_DISCOVERY_SIGNALS.map((signal) => <li>{signal}</li>)}
        </ul>
        <p class="text-muted discovery-note">
          We expect discovery to come first from public posts, owner submissions, screenshots, and manual in-app testing after launch.
        </p>
      </div>
    </div>
  </section>

  <section class="section" id="submit">
    <div class="container">
      <div class="submit-section">
        <div class="submit-header">
          <h2>Want to List Your Group?</h2>
          <p class="text-secondary prose-body">
            Submit your XChat group for free, or pay once to pin it at the top of its category. Once live data exists, this page is ready to publish it.
          </p>
        </div>
        <div class="submit-cta">
          <a href="/list-your-group" class="btn btn-primary btn-lg">
            See Listing Options
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <p class="text-muted" style="font-size: 0.8125rem; margin-top: 0.875rem;">Free listing available · $9 featured pin · $29 lifetime</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .groups-hero {
    text-align: center;
    padding-bottom: 2rem;
  }

  .groups-title {
    margin-bottom: 1.25rem;
  }

  .groups-title .text-gradient {
    display: block;
    margin-top: 0.15em;
  }

  .groups-subtitle {
    font-size: 1.0625rem;
    max-width: 600px;
    margin: 0 auto 2.25rem;
    line-height: 1.55;
    text-wrap: pretty;
  }

  .groups-subtitle strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  .search-box {
    position: relative;
    max-width: 560px;
    margin: 0 auto 1.5rem;
  }

  .search-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
    pointer-events: none;
  }

  .search-box input {
    padding-left: 2.75rem;
    border-radius: var(--radius-full);
    background: var(--bg-secondary);
    font-size: 0.9375rem;
    height: 3rem;
  }

  .tags-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1rem;
  }

  .group-card {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .group-card-header {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .group-icon {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    flex-shrink: 0;
  }

  .group-name {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .group-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .group-category {
    padding: 0.125rem 0.5rem;
    font-size: 0.6875rem;
  }

  .group-badge,
  .group-verified {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-full);
    font-size: 0.6875rem;
    font-weight: 600;
  }

  .group-badge-featured {
    background: rgba(29, 155, 240, 0.12);
    color: var(--accent-light);
  }

  .group-badge-lifetime {
    background: rgba(245, 158, 11, 0.14);
    color: #fbbf24;
  }

  .group-verified {
    background: rgba(34, 197, 94, 0.12);
    color: #4ade80;
  }

  .group-desc {
    font-size: 0.875rem;
    line-height: 1.6;
    flex: 1;
  }

  .group-tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .mini-tag {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.5rem;
    border-radius: var(--radius-full);
    background: rgba(255, 255, 255, 0.04);
    color: var(--text-muted);
    font-size: 0.75rem;
  }

  .group-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: auto;
  }

  .members-info {
    flex: 1;
    min-width: 0;
  }

  .members-bar {
    height: 4px;
    background: var(--bg-secondary);
    border-radius: 2px;
    overflow: hidden;
    margin-bottom: 0.25rem;
  }

  .members-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent), var(--accent-light));
    border-radius: 2px;
    transition: width 0.3s ease;
  }

  .members-count {
    font-size: 0.6875rem;
    font-family: var(--font-mono);
  }

  .owner-removal {
    display: block;
    margin-top: 0.875rem;
    padding-top: 0.625rem;
    border-top: 1px dashed var(--border);
    font-size: 0.6875rem;
    color: var(--text-muted);
    text-decoration: none;
    text-align: right;
    opacity: 0.6;
    transition: opacity 0.2s, color 0.2s;
  }

  .owner-removal:hover {
    opacity: 1;
    color: var(--text-secondary);
  }

  /* ---- Browse by Category ---- */
  .browse-categories {
    border-top: 1px solid var(--border);
    padding-top: 3rem;
  }

  .cat-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .cat-header h2 {
    margin-bottom: 0.5rem;
  }

  .cat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }

  .cat-card {
    display: block;
    padding: 1.25rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--bg-card);
    text-decoration: none;
    transition: border-color 0.2s, transform 0.2s;
  }

  .cat-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .cat-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    margin-bottom: 0.5rem;
    border-radius: 10px;
    background: rgba(29, 155, 240, 0.12);
    color: var(--accent);
    line-height: 1;
  }

  .cat-card h3 {
    font-size: 1rem;
    margin-bottom: 0.375rem;
    color: var(--text-primary);
  }

  .cat-card p {
    font-size: 0.8125rem;
    line-height: 1.5;
    margin: 0;
  }

  .submit-section {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
  }

  .submit-header {
    margin-bottom: 2rem;
  }

  .submit-header p {
    margin-top: 0.75rem;
  }

  .submit-cta {
    margin-top: 1.5rem;
  }

  .btn-lg {
    padding: 0.875rem 2rem;
    font-size: 1.0625rem;
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
  }

  .btn-lg svg {
    flex-shrink: 0;
  }

  .coming-soon-state,
  .discovery-card {
    text-align: center;
    padding: 4.5rem 2rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    max-width: 720px;
    margin: 0 auto;
    background:
      radial-gradient(ellipse at top, rgba(29, 155, 240, 0.04), transparent 60%),
      var(--bg-card);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.04) inset,
      0 1px 2px rgba(0, 0, 0, 0.4);
    position: relative;
    overflow: hidden;
  }

  .coming-soon-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    margin-bottom: 1.25rem;
    color: var(--accent-light);
    background: rgba(29, 155, 240, 0.08);
    position: relative;
  }

  .coming-soon-icon::before {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 1px solid rgba(29, 155, 240, 0.3);
    animation: radar-pulse 2.8s ease-out infinite;
  }

  @keyframes radar-pulse {
    0% { transform: scale(1); opacity: 0.8; }
    100% { transform: scale(1.6); opacity: 0; }
  }

  .coming-soon-state h3,
  .discovery-card h2 {
    margin-bottom: 0.75rem;
  }

  .coming-soon-state p,
  .discovery-card p {
    max-width: 520px;
    margin-left: auto;
    margin-right: auto;
  }

  .coming-soon-hint {
    font-size: 0.875rem;
    margin-top: 1rem;
  }

  .coming-soon-hint a {
    color: var(--accent-light);
    font-weight: 500;
  }

  .discovery-list {
    margin: 1.5rem auto 0;
    max-width: 520px;
    text-align: left;
    color: var(--text-secondary);
    line-height: 1.7;
    padding-left: 1.25rem;
  }

  .discovery-list li + li {
    margin-top: 0.5rem;
  }

  .discovery-note {
    margin-top: 1rem;
    font-size: 0.875rem;
  }

  .empty-state {
    text-align: center;
    padding: 3rem 0;
  }

  @media (max-width: 640px) {
    .grid {
      grid-template-columns: 1fr;
    }

    .coming-soon-state,
    .discovery-card {
      padding: 3rem 1.25rem;
    }
  }
</style>

<script>
  const tags = document.querySelectorAll<HTMLButtonElement>('.tags-row .tag');
  const cards = document.querySelectorAll<HTMLElement>('.group-card');
  const emptyState = document.getElementById('empty-state');
  const searchInput = document.getElementById('group-search') as HTMLInputElement | null;
  let activeCategory = 'All';

  function updateVisibleGroups() {
    const query = searchInput?.value.toLowerCase().trim() || '';
    let visibleCount = 0;

    cards.forEach((card) => {
      const categoryMatch = activeCategory === 'All' || card.dataset.category === activeCategory;
      const text = card.dataset.search?.toLowerCase() || card.textContent?.toLowerCase() || '';
      const searchMatch = !query || text.includes(query);
      const match = categoryMatch && searchMatch;

      card.style.display = match ? '' : 'none';
      if (match) visibleCount++;
    });

    if (emptyState) {
      emptyState.style.display = cards.length > 0 && visibleCount === 0 ? 'block' : 'none';
    }
  }

  const urlParams = new URLSearchParams(window.location.search);
  const initialQuery = urlParams.get('q');

  tags.forEach((tag) => {
    tag.addEventListener('click', () => {
      tags.forEach((t) => {
        t.classList.remove('active');
        t.setAttribute('aria-selected', 'false');
      });
      tag.classList.add('active');
      tag.setAttribute('aria-selected', 'true');
      activeCategory = tag.dataset.category || 'All';
      updateVisibleGroups();
    });
  });

  searchInput?.addEventListener('input', updateVisibleGroups);

  if (initialQuery && searchInput) {
    searchInput.value = initialQuery;
    updateVisibleGroups();
  }
</script>
