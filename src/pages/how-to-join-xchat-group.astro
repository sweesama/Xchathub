---
/**
 * how-to-join-xchat-group.astro — 加入 XChat 群组完整教程
 *
 * SEO 战略：拦截高 commercial-intent 长尾词
 *   "how to join xchat group", "xchat group invite link", "join xchat group chat",
 *   "xchat group link not working", "click xchat invite link"
 *
 * 漏斗位置：文章直接把流量推到 /groups（目录）和 /list-your-group（提交）
 */
import Layout from '../layouts/Layout.astro';
import {
  XCHAT_APP_STORE_URL,
  XCHAT_GROUP_LIMIT,
  XCHAT_TELEGRAM_CHANNEL_URL,
} from '../data/xchat';

const datePublished = '2026-04-25';
const dateModified = '2026-04-27';

/* HowTo schema — 让 Google 把步骤展示成 rich result */
const howToJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to Join an XChat Group',
  description:
    'Step-by-step guide to join a public XChat group via an invite link, including what to do when the link does not open or your join request is pending.',
  totalTime: 'PT2M',
  tool: [
    { '@type': 'HowToTool', name: 'XChat app (iOS) or chat.x.com web client' },
    { '@type': 'HowToTool', name: 'X account' },
    { '@type': 'HowToTool', name: 'A public XChat group invite link' },
  ],
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: 'Find a legitimate XChat group invite link',
      text: 'Find a public XChat invite link from a source you trust — for example the XChat Hub directory or a tweet from the group owner. Real links start with https://x.com/i/chat/group_join/.',
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: 'Open the link on a device with XChat',
      text: 'Tap the link from your iPhone or iPad with XChat installed. iOS opens the link directly inside XChat. On Android or desktop, open the link inside chat.x.com after signing in to your X account.',
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: 'Send a join request',
      text: 'XChat shows the group preview (name, member count, admins). Tap "Request to Join". Your request is queued for the admin to approve.',
    },
    {
      '@type': 'HowToStep',
      position: 4,
      name: 'Wait for admin approval',
      text: 'Admins receive your request inside the group info panel. Approval is usually within minutes for active groups. You will receive a notification when accepted.',
    },
  ],
};

const steps = [
  {
    n: 1,
    title: 'Find a legitimate XChat invite link',
    body: 'Real XChat invite links always start with <code>https://x.com/i/chat/group_join/</code>. Get them from sources you trust — the <a href="/groups">XChat Hub directory</a>, a tweet from the group owner, or a direct share. Avoid links posted by bot accounts.',
    tip: 'If a "free crypto signals" account drops a link with no other context, treat it as suspicious. Real groups have history.',
  },
  {
    n: 2,
    title: 'Open the link on a device that has XChat',
    body: 'On iPhone or iPad with XChat installed, tap the link — iOS opens it inside XChat automatically. On Android, Windows, macOS or Linux, sign in to <a href="/web">chat.x.com</a> first, then paste the link into your browser address bar.',
    tip: 'If the link opens in your X feed instead of XChat, force-quit X, open XChat, and try again. The link can also be pasted directly into the XChat search bar.',
  },
  {
    n: 3,
    title: 'Tap "Request to Join"',
    body: 'XChat shows you a group preview — group name, description, member count, and admin handles. Tap <strong>Request to Join</strong>. The button changes to <strong>Pending</strong> until an admin reviews you.',
    tip: 'You can cancel a pending request from the same screen if you change your mind before approval.',
  },
  {
    n: 4,
    title: 'Wait for the admin to approve',
    body: 'Admins receive join requests inside the group info panel. Approval is usually fast for active groups, but can take longer for high-volume invites. When you are accepted, XChat sends a push notification and the group appears in your inbox.',
    tip: 'Cap is currently {XCHAT_GROUP_LIMIT} members. Some popular groups may pause invites once they hit the cap until X expands it toward 1,000.',
  },
];

const troubles = [
  {
    q: 'The link opens a "Group not found" error.',
    a: 'The link expired or the admin disabled the public link toggle. Ask the group owner to generate a fresh link.',
  },
  {
    q: 'The link opens X.com instead of XChat.',
    a: 'Either XChat is not installed, or X is intercepting the URL. On iOS, install XChat and try again. On Android/desktop, sign in to chat.x.com and paste the URL there.',
  },
  {
    q: 'My join request stays "Pending" forever.',
    a: 'The group owner has not reviewed it yet, or the group is full. Move on after 48 hours and find another group in the <a href="/groups">directory</a>.',
  },
  {
    q: '"This group is full" message.',
    a: `XChat caps groups at ${XCHAT_GROUP_LIMIT} members at launch. The cap is being raised toward 1,000 — try again later, or pick a smaller group with the same topic.`,
  },
  {
    q: 'I am asked to verify my account.',
    a: 'Your X account may not meet the group\'s minimum requirements (account age, verified email, etc.). Add a phone number to your X account and try again.',
  },
];

const faqs = [
  {
    q: 'Are XChat group invite links public?',
    a: 'They are unlisted by default. Anyone who has the URL can request to join, but XChat does not publish a master list of links. Communities like the <a href="/groups">XChat Hub directory</a> aggregate the ones owners choose to share.',
  },
  {
    q: 'Can I join an XChat group from Android?',
    a: 'Yes — open <a href="/web">chat.x.com</a> in your Android browser, sign in, then paste the invite URL. The native iOS app is not required for joining.',
  },
  {
    q: 'Do I need an X Premium subscription to join?',
    a: 'No. XChat itself is free. Some groups (premium creator communities) may restrict membership to subscribers, but joining a generic public group does not require Premium.',
  },
  {
    q: 'Can the admin see my IP address or phone number?',
    a: 'No. Admins only see your X handle, profile photo, and verification badges. XChat does not share IP or device data with group admins.',
  },
  {
    q: 'How do I leave an XChat group later?',
    a: 'Open the group, tap the group name, scroll to the bottom of the info panel, and tap "Leave Group". Leaving is silent — other members do not get notified.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') },
  })),
};
---

<Layout
  title="How to Join an XChat Group: Public Invite Links Explained"
  description="Step-by-step guide to join an XChat group via a public invite link — for iOS, Android (web), and desktop. Includes troubleshooting for pending and expired links."
  jsonLd={howToJsonLd}
  canonicalPath="/how-to-join-xchat-group"
  ogImage="/og-groups.png"
  ogImageAlt="How to join public XChat groups — directory and tutorial at xchat.directory"
  breadcrumbs={[
    { name: 'Home', url: 'https://xchat.directory/' },
    { name: 'How to Join an XChat Group', url: 'https://xchat.directory/how-to-join-xchat-group/' },
  ]}
>
  <article>
    <!-- HERO -->
    <section class="section hero">
      <div class="container">
        <span class="eyebrow">Tutorial · Updated {dateModified}</span>
        <h1>How to Join an XChat Group: Public Invite Links Explained</h1>
        <p class="lead text-secondary prose-body">
          Joining an XChat group is a 4-step flow: find a real invite link, open it on a
          device with XChat, request to join, and wait for the admin to approve.
          This guide covers the link format, iOS, Android web fallback, and the most common
          errors people hit.
        </p>
        <div class="cta-buttons">
          <a href="/groups" class="btn btn-primary btn-lg">Browse the Groups Directory →</a>
          <a href={XCHAT_APP_STORE_URL} target="_blank" rel="noopener noreferrer" class="btn btn-secondary btn-lg">
            Install XChat (iOS)
          </a>
        </div>
      </div>
    </section>

    <!-- QUICK SUMMARY -->
    <section class="section-sm">
      <div class="container">
        <div class="tldr-card">
          <h2>Quick Summary</h2>
          <ol>
            <li>Get a real XChat invite link starting with <code>https://x.com/i/chat/group_join/</code>.</li>
            <li>Tap the link on iPhone/iPad with XChat installed, or paste it into <a href="/web">chat.x.com</a> on Android/desktop.</li>
            <li>Tap <strong>Request to Join</strong>.</li>
            <li>Wait for the admin to approve — minutes for active groups.</li>
          </ol>
        </div>
      </div>
    </section>

    <!-- DETAILED STEPS -->
    <section class="section steps-section" id="steps">
      <div class="container">
        <h2 class="section-title">Detailed Walkthrough</h2>
        <div class="steps">
          {steps.map((s) => (
            <article class="step-card">
              <div class="step-num" aria-hidden="true">{s.n}</div>
              <div class="step-body">
                <h3>{s.title}</h3>
                <p class="text-secondary" set:html={s.body} />
                <div class="step-tip"><strong>Tip:</strong> {s.tip}</div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- WHERE TO FIND -->
    <section class="section-sm content-section" id="where">
      <div class="container">
        <h2>Where to Find Real XChat Invite Links</h2>
        <p class="prose-body text-secondary">
          The link format is always
          <code>https://x.com/i/chat/group_join/&lt;groupId&gt;/&lt;token&gt;</code>.
          Anything else is not a valid XChat group link.
        </p>
        <ul class="feature-list">
          <li><a href="/groups">XChat Hub Groups Directory</a> — community-reviewed list, browsable by topic.</li>
          <li>Tweets from the group owner — admins often pin the invite to their profile.</li>
          <li>Owner websites or newsletters — many creators publish their links on their own domain.</li>
          <li>Direct share from someone already inside the group.</li>
        </ul>
        <div class="callout callout-warning">
          <strong>Avoid:</strong> "XChat invite" links shared by anonymous bot accounts, links shortened through obscure URL shorteners, or any link that asks you to "verify" your X password before joining. None of those are needed for a real XChat group.
        </div>
      </div>
    </section>

    <!-- TROUBLESHOOTING -->
    <section class="section-sm content-section" id="troubleshooting">
      <div class="container">
        <h2>Troubleshooting: Why an XChat Group Link Might Not Work</h2>
        <div class="faq-list">
          {troubles.map((t) => (
            <details class="faq-item">
              <summary>{t.q}</summary>
              <p class="text-secondary" set:html={t.a} />
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section faq-section" id="faq">
      <div class="container">
        <h2 class="section-title">Frequently Asked Questions</h2>
        <div class="faq-list">
          {faqs.map((f) => (
            <details class="faq-item">
              <summary>{f.q}</summary>
              <p class="text-secondary" set:html={f.a} />
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- RELATED -->
    <section class="section related-section">
      <div class="container">
        <h2 class="section-title">Next Steps</h2>
        <div class="related-grid">
          <a href="/groups" class="related-card">
            <h3>Browse XChat Groups Directory →</h3>
            <p class="text-secondary">10 categories, curated invite links, updated weekly.</p>
          </a>
          <a href="/how-to-create-group-link" class="related-card">
            <h3>Create Your Own Group Link →</h3>
            <p class="text-secondary">If you run a community, here is the 6-step creation tutorial.</p>
          </a>
          <a href="/list-your-group" class="related-card">
            <h3>List Your Group →</h3>
            <p class="text-secondary">Submit your group invite to the directory — free, reviewed within 24h.</p>
          </a>
          <a href={XCHAT_TELEGRAM_CHANNEL_URL} target="_blank" rel="noopener noreferrer" class="related-card">
            <h3>Get Updates on Telegram →</h3>
            <p class="text-secondary">New groups, feature drops, and Android tracker updates.</p>
          </a>
        </div>
      </div>
    </section>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
</Layout>

<style>
  .hero {
    text-align: center;
    padding-top: 4rem;
    padding-bottom: 2rem;
  }

  .eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-light);
    margin-bottom: 1rem;
    padding: 0.3125rem 0.875rem;
    border: 1px solid rgba(29, 155, 240, 0.25);
    border-radius: var(--radius-full);
    background: rgba(29, 155, 240, 0.05);
  }

  .hero h1 {
    max-width: 820px;
    margin: 0 auto 1.25rem;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
  }

  .lead {
    font-size: 1.0625rem;
    max-width: 720px;
    margin: 0 auto 1.5rem;
  }

  .cta-buttons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.875rem;
  }

  .tldr-card {
    max-width: 760px;
    margin: 0 auto;
    padding: 1.75rem 2rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    background: var(--bg-card);
  }

  .tldr-card h2 {
    margin-bottom: 1rem;
    font-size: 1.125rem;
  }

  .tldr-card ol {
    margin: 0;
    padding-left: 1.25rem;
    color: var(--text-secondary);
    line-height: 1.85;
  }

  .tldr-card li + li {
    margin-top: 0.375rem;
  }

  .tldr-card code,
  .content-section code {
    background: rgba(29, 155, 240, 0.08);
    color: var(--accent-light);
    padding: 0.1em 0.4em;
    border-radius: 0.25rem;
    font-size: 0.875em;
  }

  .steps {
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .step-card {
    display: flex;
    gap: 1.25rem;
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    background: var(--bg-card);
  }

  .step-num {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(29, 155, 240, 0.12);
    color: var(--accent-light);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
  }

  .step-body h3 {
    font-size: 1.0625rem;
    margin-bottom: 0.5rem;
  }

  .step-tip {
    margin-top: 0.625rem;
    padding: 0.625rem 0.875rem;
    border-left: 3px solid var(--accent);
    background: rgba(29, 155, 240, 0.05);
    border-radius: 0 0.375rem 0.375rem 0;
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  .content-section h2 {
    max-width: 760px;
    margin: 0 auto 1rem;
    font-size: 1.5rem;
  }

  .content-section .prose-body,
  .content-section .feature-list,
  .content-section .faq-list {
    max-width: 760px;
    margin-left: auto;
    margin-right: auto;
  }

  .feature-list {
    list-style: disc;
    padding-left: 1.25rem;
    color: var(--text-secondary);
    line-height: 1.8;
  }

  .feature-list li + li {
    margin-top: 0.5rem;
  }

  .feature-list a {
    color: var(--accent-light);
  }

  .callout {
    max-width: 760px;
    margin: 1.5rem auto 0;
    padding: 1rem 1.25rem;
    border-radius: var(--radius-lg);
    border: 1px solid;
  }

  .callout-warning {
    background: rgba(245, 197, 24, 0.06);
    border-color: rgba(245, 197, 24, 0.25);
    color: #f5c518;
  }

  .faq-section {
    border-top: 1px solid var(--border);
  }

  .faq-list {
    max-width: 760px;
    margin: 0 auto;
  }

  .faq-item {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--bg-card);
    padding: 1rem 1.25rem;
    margin-bottom: 0.75rem;
  }

  .faq-item summary {
    cursor: pointer;
    font-weight: 600;
  }

  .faq-item p {
    margin-top: 0.75rem;
    line-height: 1.7;
  }

  .related-card {
    display: block;
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--bg-card);
    text-decoration: none;
    transition: border-color 0.2s, transform 0.2s;
  }

  .related-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .related-card h3 {
    color: var(--text-primary);
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }

  .related-card p {
    font-size: 0.875rem;
    margin: 0;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
  }

  .section-title {
    text-align: center;
    margin-bottom: 1.5rem;
  }
</style>
